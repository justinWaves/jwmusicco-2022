# ─── JW Music Co — Environment Variables ────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key at: https://resend.com (free tier: 100 emails/day)
# Step 1: Create a free Resend account
# Step 2: Go to API Keys → Create API Key
# Step 3: Paste it here

RESEND_API_KEY=re_ggJ17oW6_3ovY4U142UBRctRGvs5J7Gkw

# The email address that receives all site inquiries
CONTACT_EMAIL=jwmusicco@gmail.com
# The "from" address shown to recipients.
# IMPORTANT: Requires domain verification in Resend before using a custom domain.
# During testing, leave this unset to use the Resend sandbox sender automatically.
RESEND_FROM=JW Music Co <noreply@jwmusicco.com>

# ─── Booking (Cal.com) ───────────────────────────────────────────────────────
# Get started at: https://cal.com (free tier available)
# Step 1: Create a Cal.com account
# Step 2: Create an Event Type (e.g. "30-min Discovery Call")
# Step 3: Get your booking URL: https://cal.com/YOUR-USERNAME/EVENT-SLUG
# Step 4: Append ?embed=true for the iframe embed version

# Format: "your-cal-username/event-slug" — no https://, no cal.com prefix
# Recording sessions scheduler
# NEXT_PUBLIC_CAL_RECORDING_LINK=justinwaves/recording-session

# Lessons scheduler
# NEXT_PUBLIC_CAL_LESSONS_LINK=justinwaves/music-lesson

# ─── Site ─────────────────────────────────────────────────────────────────────
# Set this in Vercel environment variables for production
NEXT_PUBLIC_SITE_URL=https://jwmusicco.com
